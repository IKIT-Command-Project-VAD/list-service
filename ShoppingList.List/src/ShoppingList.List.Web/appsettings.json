{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Authentication": {
    "Authority": "http://localhost:9100/realms/ShoppingList",
    "Audience": "ShoppingList.List",
    "RequireHttps": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Mailserver": {
    "Server": "localhost",
    "Port": 25
  }
}